{
  "expo": {
    "name": "Planera AI Travel Planner",
    "slug": "planera-ai-travel-planner",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/appicon-1024x1024-01-9h6cls.jpg",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/appicon-1024x1024-01-9h6cls.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FAF9F6"
    },
    "ios": {
      "supportsTablet": false,
      "newArchEnabled": true,
      "bundleIdentifier": "com.dstroump.planeraaitravelplanner",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Planera needs access to your photo library so you can select a profile photo.",
        "NSLocationWhenInUseUsageDescription": "Planera uses your location to show your position on the trip map, help you navigate to activities, and notify you when you are near a planned stop on your itinerary."
      },
      "splash": {
        "image": "./assets/images/appicon-1024x1024-01-9h6cls.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#FAF9F6"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/appicon-1024x1024-01-9h6cls.jpg",
        "backgroundColor": "#FAF9F6"
      },
      "newArchEnabled": true,
      "splash": {
        "image": "./assets/images/appicon-1024x1024-01-9h6cls.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#FAF9F6"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/appicon-1024x1024-01-9h6cls.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF9F6"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-iap",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Planera uses your location to show your position on the trip map, help you navigate to activities, and notify you when you are near a planned stop on your itinerary."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/appicon-1024x1024-01-9h6cls.jpg",
          "color": "#1B3F92",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ac0a8a4-c019-48ac-b8a3-4651a864b089"
      }
    }
  }
}
