{
  "name": "planera-ai-travel-planner",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "dev": "bunx convex dev",
    "check-bundle": "node scripts/check-bundle-safety.js",
    "prebuild": "node scripts/check-bundle-safety.js",
    "postinstall": "patch-package && node scripts/fix-better-auth.js",
    "verify-versions": "node -e \"const p=require('./package.json');console.log('expo:',p.dependencies.expo);console.log('react-native:',p.dependencies['react-native']);console.log('reanimated:',p.dependencies['react-native-reanimated']);console.log('gesture-handler:',p.dependencies['react-native-gesture-handler']);\""
  },
